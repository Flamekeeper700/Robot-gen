{
    "TalonFX": {
        "name": "TalonFX",
        "imports": [
            "com.ctre.phoenix6.hardware.TalonFX",
            "com.ctre.phoenix6.configs.TalonFXConfiguration",
            "com.ctre.phoenix6.signals.NeutralModeValue",
            "com.ctre.phoenix6.signals.InvertedValue",
            "com.ctre.phoenix6.controls.Follower",
            "com.ctre.phoenix6.controls.DutyCycleOut"
        ],
        "declaration": "private final TalonFX {{varName}} = new TalonFX({{id}}, \"{{canBus}}\");",
        "leaderConfig": [
        "var leaderConfig = new TalonFXConfiguration();",
        "leaderConfig.CurrentLimits.SupplyCurrentLimit = {{currentLimit}};",
        "leaderConfig.CurrentLimits.SupplyCurrentLimitEnable = true;",
        "leaderConfig.MotorOutput.NeutralMode = NeutralModeValue.{{idleMode}}Value;",
        "leaderConfig.MotorOutput.Inverted = {{#if inverted}}InvertedValue.Clockwise_Positive{{else}}InvertedValue.CounterClockwise_Positive{{/if}};",
        "{{varName}}.getConfigurator().apply(leaderConfig);"
        ],
        "followerConfig": [
            "var followerConfig = new TalonFXConfiguration();",
            "followerConfig.CurrentLimits.SupplyCurrentLimit = {{currentLimit}};",
            "followerConfig.CurrentLimits.SupplyCurrentLimitEnable = true;",
            "followerConfig.MotorOutput.NeutralMode = NeutralModeValue.{{idleMode}}Value;",
            "{{varName}}.getConfigurator().apply(followerConfig);",
            "{{varName}}.setControl(new Follower({{leaderId}}, {{oppose}}));"
        ],
        "getVelocity": "{{varName}}.getVelocity().getValueAsDouble()",
        "getPosition": "{{varName}}.getPosition().getValueAsDouble()"
    },
    "SparkMax": {
        "name": "SPARK MAX (Brushless)",
        "imports": [
            "com.revrobotics.spark.SparkMax",
            "com.revrobotics.spark.SparkBase",
            "com.revrobotics.spark.config.SparkMaxConfig",
            "com.revrobotics.spark.config.SparkBaseConfig"
        ],
        "declaration": "private final SparkMax {{varName}} = new SparkMax({{id}}, SparkLowLevel.MotorType.kBrushless);",
        "leaderConfig": [
            "var leaderConfig = new SparkMaxConfig();",
            "leaderConfig.smartCurrentLimit({{currentLimit}});",
            "leaderConfig.idleMode(SparkBaseConfig.IdleMode.k{{idleMode}});",
            "leaderConfig.inverted({{inverted}});",
            "{{varName}}.configure(leaderConfig, SparkBase.ResetMode.kResetSafeParameters, SparkBase.PersistMode.kPersistParameters);"
        ],
        "followerConfig": [
            "var followerConfig = new SparkMaxConfig();",
            "followerConfig.smartCurrentLimit({{currentLimit}});",
            "followerConfig.idleMode(SparkBaseConfig.IdleMode.k{{idleMode}});",
            "followerConfig.follow({{leaderVar}}, {{oppose}});",
            "{{varName}}.configure(followerConfig, SparkBase.ResetMode.kResetSafeParameters, SparkBase.PersistMode.kPersistParameters);"
        ],
        "getVelocity": "{{varName}}.getEncoder().getVelocity()",
        "getPosition": "{{varName}}.getEncoder().getPosition()"
    }
}