{
  "metadata": {
    "libraryName": "UniversalNetworkClient",
    "version": "4.2.0"
  },
  "classes": {
    "NetworkDevice": {
      "package": "org.universal.network",
      "imports": [
        "org.universal.network.NetworkDevice"
      ],
      "constructors": [
        {
          "parameters": [
            {
              "name": "id",
              "type": "int"
            }
          ]
        }
      ],
      "methods": {
        "connect": {
          "returnType": "void",
          "parameters": [
            {
              "name": "port",
              "type": "int"
            }
          ],
          "template": "${instance}.connect(${port});"
        },
        "isConnected": {
          "returnType": "boolean",
          "parameters": [],
          "template": "${instance}.isConnected();"
        }
      }
    }
  }
}